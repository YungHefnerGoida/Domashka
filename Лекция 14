"""
import random

nested_list = [[random.randint(1, 100) for _ in range(4)] for _ in range(3)]

print("Сгенерированный список:")
for row in nested_list:
    print(row)

row_sums = []
max_sum = 0
max_row_index = 0

for i in range(len(nested_list)):
    current_sum = 0
    for j in range(len(nested_list[i])):
        current_sum += nested_list[i][j]
    row_sums.append(current_sum)
    
    if current_sum > max_sum:
        max_sum = current_sum
        max_row_index = i

total_sum = sum(row_sums)

for i, s in enumerate(row_sums):
    print(f"Сумма строки {i}: {s}")
print(f"Общая сумма всех элементов: {total_sum}")
print(f"Строка с максимальной суммой: {max_row_index} (сумма = {max_sum})")
