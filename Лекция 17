def is_prime(num):
    if num <= 1:
        return False
    for i in range(2,int(num**0.5)+1):
        if num % i == 0:
            return False
    return True
def get_next_prime(num):
    prime = num + 1
    while not is_prime(prime):
        prime += 1
    return prime

