def is_password_good(password):
    upper_count = sum(1 for char in password if char.isupper())
    lower_count = sum(1 for char in password if char.islower())
    digit_count = sum(1 for char in password if char.isdigit())
    if len(password) < 8:
        return False
    elif upper_count <= 1:
        return False
    elif lower_count <= 1:
        return False
    elif digit_count <= 1:
        return False
    else:
        return True
